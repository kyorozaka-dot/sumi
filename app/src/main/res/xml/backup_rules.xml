<?xml version="1.0" encoding="utf-8"?>
<!--
  バックアップルール (API < 31 向け)
  EncryptedSharedPreferences に保存した APIキーは端末固有のキーで暗号化されているため、
  他の端末にリストアしても復号できない。バックアップから明示的に除外する。
-->
<full-backup-content>
    <exclude domain="sharedpref" path="sumi_secure_prefs" />
    <exclude domain="sharedpref" path="sumi_secure_prefs.xml" />
</full-backup-content>
