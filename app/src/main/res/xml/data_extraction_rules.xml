<?xml version="1.0" encoding="utf-8"?>
<!--
  データ抽出ルール (API 31+ 向け)
  EncryptedSharedPreferences の APIキーをクラウドバックアップ・端末転送から除外する。
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="sumi_secure_prefs" />
        <exclude domain="sharedpref" path="sumi_secure_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="sumi_secure_prefs" />
        <exclude domain="sharedpref" path="sumi_secure_prefs.xml" />
    </device-transfer>
</data-extraction-rules>
